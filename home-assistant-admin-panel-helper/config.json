{
  "name": "Home Assistant Admin Panel Helper",
  "version": "1.0.0",
  "slug": "home_assistant_admin_panel_helper",
  "description": "A proxy to expose selected Supervisor API calls for Home Assistant Admin Panel",
  "startup": "services",
  "boot": "auto",
  "host_network": true,
  "ingress": false,
  "panel_admin": true,
  "panel_icon": "mdi:api",
  "options": {},
  "schema": { "api_key": "str" },
  "privileged": ["NET_ADMIN", "SYS_ADMIN"],
  "hassio_api": true,
  "hassio_role": "admin",
  "auth_api": true,
  "map": ["config:rw"],
  "panel_custom": {
    "url_path": "api/myaddon",
    "sidebar_title": "My Addon API",
    "sidebar_icon": "mdi:api",
    "require_admin": true
  },
  "arch": ["aarch64", "amd64", "armhf", "armv7", "i386"]
}
